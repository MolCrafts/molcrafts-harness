{
  "description": "Validate the MolCrafts plugin marketplace after plugin-source edits.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/scripts/validate_repository.py\" --root-from-cwd --quiet",
            "timeout": 30,
            "statusMessage": "Validating MolCrafts plugin structure"
          }
        ]
      }
    ]
  }
}
